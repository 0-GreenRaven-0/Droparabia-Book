---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PL74V6DG');</script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <title>Book Your Call — Droparabia</title>
    <link rel="icon" type="image/png" href="/Droparabia.png" />
    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
      .cal-spinner {
        width: 40px; height: 40px;
        border: 3px solid #e2e8f0;
        border-top-color: #2563eb;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        flex-shrink: 0;
      }
      @media (max-width: 768px) {
        .cal-heading { font-size: 1.15rem !important; }
      }
    </style>
  </head>

  <body style="background:#f8fafc; min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:2rem 1rem 0;">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PL74V6DG"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <h1 class="cal-heading" style="font-family:'DM Sans',sans-serif; font-size:clamp(1.4rem,3vw,2rem); font-weight:700; color:#1f2937; text-align:center; margin:0 0 1.5rem;">
      Select the time that best suits you
    </h1>

    <!-- Wrapper so loader can overlay the widget -->
    <div style="position:relative; width:100%; max-width:1100px; flex:1;">

      <!-- Loading overlay -->
      <div id="cal-loader" style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; background:#f8fafc; z-index:10;">
        <div class="cal-spinner"></div>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9rem; color:#6b7280; margin:0;">Wait for the booking form to load</p>
      </div>

      <!-- Calendly inline widget begin -->
      <div class="calendly-inline-widget" data-url="https://calendly.com/d/cr37-8xm-k5s/45-min-lead-advisory-call" style="min-width:320px; height:900px;"></div>
      <script is:inline type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- Calendly inline widget end -->

    </div>

    <script is:inline>
      window.addEventListener('message', function(e) {
        if (e.data && e.data.event === 'calendly.profile_page_viewed') {
          document.getElementById('cal-loader').style.display = 'none';
        }
        if (e.data && e.data.event === 'calendly.event_scheduled') {
          var invitee = (e.data.payload && e.data.payload.invitee) || {};
          var name    = invitee.name  || '';
          var email   = invitee.email || '';
          var phone   = invitee.text_reminder_number || '';

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'call_booked', name: name, email: email });

          if (email) {
            fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name: name, email: email, phone: phone, list: 'booked' })
            }).catch(function() {});
          }

          setTimeout(function() {
            window.location.href = 'https://thank-you.droparabia.com';
          }, 500);
        }
      });

      // Fallback: reveal after 5s
      setTimeout(function() {
        var loader = document.getElementById('cal-loader');
        if (loader) loader.style.display = 'none';
      }, 5000);
    </script>

  </body>
</html>
