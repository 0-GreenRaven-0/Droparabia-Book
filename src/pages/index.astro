    <script>
      document.querySelectorAll('.faq-item').forEach(item => {
        const summary = item.querySelector('summary');

        summary.addEventListener('click', e => {
          e.preventDefault();

          if (item.open) {
            const anim = item.animate([
              { height: item.offsetHeight + 'px' },
              { height: summary.offsetHeight + 'px' }
            ], { duration: 280, easing: 'ease' });
            item.style.overflow = 'hidden';
            anim.onfinish = () => {
              item.open = false;
              item.style.height = '';
              item.style.overflow = '';
            };
          } else {
            item.open = true;
            const fullHeight = item.offsetHeight;
            item.style.overflow = 'hidden';
            item.animate([
              { height: summary.offsetHeight + 'px' },
              { height: fullHeight + 'px' }
            ], { duration: 280, easing: 'ease' });
            setTimeout(() => { item.style.overflow = ''; }, 280);
          }
        });
      });
    </script>

    <script>
      (function() {
        var timeline = document.getElementById('how-timeline');
        var track = timeline ? timeline.querySelector('.how-tl-track') : null;
        var fill = document.getElementById('how-tl-fill');
        if (!timeline || !track || !fill) return;

        // Set track height to stop at the center of the last dot
        function setTrackHeight() {
          var dots = timeline.querySelectorAll('.how-tl-dot');
          var lastDot = dots[dots.length - 1];
          var tlRect = timeline.getBoundingClientRect();
          var dotRect = lastDot.getBoundingClientRect();
          var dotCenter = dotRect.top - tlRect.top + dotRect.height / 2;
          track.style.height = dotCenter + 'px';
        }

        setTrackHeight();
        window.addEventListener('resize', setTrackHeight);

        function updateFill() {
          var rect = timeline.getBoundingClientRect();
          var vh = window.innerHeight;
          var start = rect.top - vh * 0.8;
          var end = rect.bottom - vh * 0.6;
          var progress = Math.min(1, Math.max(0, -start / (end - start)));
          fill.style.height = (progress * 100) + '%';
        }

        window.addEventListener('scroll', updateFill, { passive: true });
        updateFill();
      })();
    </script>

