    <section class="hero-section relative">
   

<div class="hero-inner">

        <!-- Attention line -->
        <p class="attention-line reveal">
          Haven't decided what kind of online business to start in 2026?
        </p>

        <!-- Headline + Subheadline + Badges box -->
        <div class="hero-content-box">

          <h1 class="hero-headline reveal">
            Build your <span class="hl-brand">high-earning</span> online store in less than <span class="hl-brand">30 days</span> with a small budget starting from <span class="hl-brand">$500</span>
          </h1>

          <p class="hero-sub reveal">
          Using Droparabia, the platform that allowed <strong>+500 Lebanese</strong> to start their own online business
          </p>

          <div class="stats-row reveal">

            <div class="stat-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="ck1" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#2563EB"/>
                    <stop offset="100%" stop-color="#29B6F6"/>
                  </linearGradient>
                </defs>
                <path d="M5 13l4 4L19 7" stroke="url(#ck1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="stat-badge-label">No Experience</span>
            </div>

            <div class="stat-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="ck2" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#2563EB"/>
                    <stop offset="100%" stop-color="#29B6F6"/>
                  </linearGradient>
                </defs>
                <path d="M5 13l4 4L19 7" stroke="url(#ck2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="stat-badge-label">No Technical Skills</span>
            </div>

            <div class="stat-badge">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <defs>
                  <linearGradient id="ck3" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#2563EB"/>
                    <stop offset="100%" stop-color="#29B6F6"/>
                  </linearGradient>
                </defs>
                <path d="M5 13l4 4L19 7" stroke="url(#ck3)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="stat-badge-label">No Huge Upfront costs</span>
            </div>

          </div>

        </div>

            <!-- CTA block -->
        <div class="cta-block reveal">
          <div class="tp-row">
            <span class="tp-excellent">Great!</span>
            <span class="tp-stars-row">
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
              <span class="tp-star">★</span>
            </span>
            <img src="/Trustpilot_Logo_(2022).svg.png" alt="Trustpilot" class="tp-logo" />
          </div>
          <a id="cta-book-call" href="https://calendly.com/d/cr37-8xm-k5s/45-min-lead-advisory-call" target="_blank" rel="noopener noreferrer" class="cta-btn">
            <span class="cta-btn-main">Book a Free Call & get instant Access!</span>
            <span class="cta-guarantee">100% Money Back Guarantee!</span>
          </a>



        </div>
    
          <h2 class="cta-heading reveal"><span class="heading-arrow" aria-hidden="true"></span> See How much our users are earning!<span class="heading-arrow" aria-hidden="true"></span></h2>
        <!-- Case-study carousel -->
        <div class="carousel-wrap reveal">
          <div class="swiper case-swiper">
            <div class="swiper-wrapper">
              <div class="swiper-slide"><img src="https://ik.imagekit.io/greenraven/MJ/Testimonials/Testo.png?tr=w-700,h-1244,cm-pad_resize,bg-FFFFFF,q-85,f-webp" alt="Community win" width="700" height="1244" loading="eager" fetchpriority="high" /></div>
