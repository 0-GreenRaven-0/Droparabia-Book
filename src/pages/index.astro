    <!-- Scroll progress ring (desktop only) -->
    <div id="scroll-ring" class="scroll-ring hidden md:flex">
      <span id="scroll-ring-label" class="scroll-ring-label">Scroll Down!</span>
      <div class="scroll-ring-circle">
        <svg class="scroll-ring-svg" viewBox="0 0 72 72" fill="none">
          <circle cx="36" cy="36" r="30" stroke="#1a1a1a" stroke-width="3.5" />
          <circle id="scroll-ring-progress" cx="36" cy="36" r="30"
            stroke="#2563EB" stroke-width="3.5"
            stroke-linecap="round"
            stroke-dasharray="188.5"
            stroke-dashoffset="188.5"
            transform="rotate(-90 36 36)"
          />
        </svg>
        <img src="/Droparabia.png" alt="" aria-hidden="true" class="scroll-ring-logo" />
      </div>
    </div>

    <script>
      const progress = document.getElementById('scroll-ring-progress');
      const label = document.getElementById('scroll-ring-label');
      const circumference = 188.5;
      let hasScrolled = false;

      function hideLabel() {
        label.style.opacity = '0';
        label.style.pointerEvents = 'none';
      }

      function updateRing() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? scrollTop / docHeight : 0;
        progress.style.strokeDashoffset = String(circumference * (1 - pct));

        if (!hasScrolled && scrollTop > 10) {
          hasScrolled = true;
          hideLabel();
        }
      }

      setTimeout(() => {
        if (!hasScrolled) {
          label.style.opacity = '1';
        }
      }, 3000);

      window.addEventListener('scroll', updateRing, { passive: true });
      updateRing();
    </script>

